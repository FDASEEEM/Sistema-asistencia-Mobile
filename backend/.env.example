PORT=4100
NODE_ENV=production

# Aiven/PostgreSQL
PG_URI=postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
PG_SSL=true

# El backend movil trabaja aislado por schema.
APODERADOS_PG_SCHEMA=test_pruebas
MOBILE_RUN_MIGRATIONS=true

# Debe ser el mismo secreto usado para firmar tokens de apoderados.
APODERADOS_JWT_SECRET=change-me

# Opcional. Dejalo vacio para aceptar clientes moviles sin Origin.
CORS_ORIGINS=

# Opcional: push Expo.
EXPO_ACCESS_TOKEN=
